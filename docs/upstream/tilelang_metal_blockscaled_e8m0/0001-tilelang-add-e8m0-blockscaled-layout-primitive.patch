+def _normalize_block_scale_layout(
+    block_scale_layout: BlockScaledLayout | None,
+    *,
+    scale_format: str | None,
+    scale_block_size: int | None,
+) -> BlockScaledLayout | None:
+    if block_scale_layout is not None:
+        if not isinstance(block_scale_layout, BlockScaledLayout):
+            raise TypeError(
+                "T.fp8_scaled_matmul block_scale_layout must be a "
+                "T.BlockScaledLayout instance"
+            )
+        if scale_format is not None and scale_format != block_scale_layout.scale_format:
+            raise ValueError(
+                "T.fp8_scaled_matmul scale_format conflicts with block_scale_layout"
+            )
+        if scale_block_size is not None and int(scale_block_size) != block_scale_layout.block_size:
+            raise ValueError(
+                "T.fp8_scaled_matmul scale_block_size conflicts with block_scale_layout"
+            )
+        return block_scale_layout
+    if scale_format == E8M0_BLOCK_K32 or int(scale_block_size or 0) == E8M0_BLOCK_SIZE:
+        return BlockScaledLayout.e8m0_k32()
+    return None
+
+
+def _block_scale_value(scale, *, axis: str, col, k, layout: BlockScaledLayout):
+    # Path C E8M0 is explicitly contracted-K-block indexed: kb = k // 32.
+    kb = k // 32
+    if axis == "B" and len(getattr(scale, "shape", ())) == 2:
+        return e8m0_to_float(scale[col, kb])
+    return e8m0_to_float(scale[kb])
+
+
 def _validate_buffers(A_fp8, A_scale, B_fp8, B_scale, C_out, *, transpose_B: bool, accum_dtype: str) -> None:
     """Sanity-check operand dtypes and 2D shape compatibility.
 
@@ -160,6 +200,9 @@ def fp8_scaled_matmul(
     *,
     transpose_B: bool = False,
     accum_dtype: str = "float32",
+    scale_format: str | None = None,
+    scale_block_size: int | None = None,
+    block_scale_layout: BlockScaledLayout | None = None,
 ) -> None:
     """Inline FP8 scaled matmul macro.
 
@@ -176,6 +219,12 @@ def fp8_scaled_matmul(
     ``transpose_B=True`` accepts B as ``(N, K)``. This is the layout used by
     Sparse-MLA QK reducers where gathered rows are contiguous.
 
+    ``block_scale_layout=T.BlockScaledLayout.e8m0_k32()`` switches scale
+    indexing from per-tensor/per-row to E8M0 K/32 block scales. The A scale is
+    indexed as ``A_scale[k // 32]``. The B scale is indexed as
+    ``B_scale[col, k // 32]`` when it is two-dimensional, or broadcast as
+    ``B_scale[k // 32]`` when it is one-dimensional.
+
     This is intentionally a DSL macro, not a target-specific intrinsic. The
     target scheduler may replace this loop with a fused Metal implementation
     when it recognizes the same op attributes.
@@ -185,6 +234,11 @@ def fp8_scaled_matmul(
         B_scale,
         C_out,
         transpose_B=transpose_B,
+        accum_dtype=accum_dtype,
     )
+    layout = _normalize_block_scale_layout(
+        block_scale_layout,
+        scale_format=scale_format,
+        scale_block_size=scale_block_size,
+    )
 
     M = _shape_extent(A_fp8, 0)
     K = _shape_extent(A_fp8, 1)
@@ -195,14 +249,22 @@ def fp8_scaled_matmul(
     if M <= 0 or N <= 0 or K <= 0:
         raise ValueError("T.fp8_scaled_matmul requires static positive M/N/K")
 
+    if layout is not None:
+        layout.validate_scale_shapes(
+            k_extent=K,
+            a_scale_shape=tuple(int(v) for v in A_scale.shape),
+            b_scale_shape=tuple(int(v) for v in B_scale.shape),
+            n_extent=N,
+        )
+
     @T.macro
     def _body():
         for i, j in T.grid(M, N):
             for k in T.serial(K):
                 a_val = T.cast(A_fp8[i, k], accum_dtype)
                 b_val = T.cast(B_fp8[j, k] if transpose_B else B_fp8[k, j], accum_dtype)
-                a_scale = A_scale[0] if _shape_extent(A_scale, 0) == 1 else A_scale[i]
-                b_scale = B_scale[0] if _shape_extent(B_scale, 0) == 1 else B_scale[j]
-                C_out[i, j] = C_out[i, j] + a_val * b_val * a_scale * b_scale
+                if layout is not None:
+                    a_scale = _block_scale_value(A_scale, axis="A", col=j, k=k, layout=layout)
+                    b_scale = _block_scale_value(B_scale, axis="B", col=j, k=k, layout=layout)
+                else:
+                    a_scale = A_scale[0] if _shape_extent(A_scale, 0) == 1 else A_scale[i]
+                    b_scale = B_scale[0] if _shape_extent(B_scale, 0) == 1 else B_scale[j]
+                C_out[i, j] = C_out[i, j] + a_val * b_val * a_scale * b_scale
 
     _body()
diff --git a/tilelang/tileop/metal_quant.py b/tilelang/tileop/metal_quant.py
--- a/tilelang/tileop/metal_quant.py
+++ b/tilelang/tileop/metal_quant.py
@@ -1,5 +1,30 @@
 """Metal quantization helpers used by TileLang FP8 schedulers."""
 
+from __future__ import annotations
+
+from typing import Any
+
+import tilelang.language as T
+
+
+def e8m0_to_float(byte: Any):
+    """Decode an E8M0 scale byte as a TileLang float32 expression.
+
+    The function is re-exported on the DSL surface as ``T.e8m0_to_float``.
+    It intentionally mirrors the Metal helper emitted by Path C kernels:
+
+    * ``byte == 0`` decodes to zero.
+    * ``byte == 0xFF`` decodes to zero.
+    * normal bytes decode as ``exp2(byte - 127)``.
+    """
+
+    zero = T.cast(0.0, "float32")
+    decoded = T.exp2(T.cast(byte, "float32") - T.cast(127.0, "float32"))
+    return T.if_then_else(
+        byte == 0,
+        zero,
+        T.if_then_else(byte == 0xFF, zero, decoded),
+    )
+
+
 def metal_fp8_e4m3_dot4(a_ptr, b_ptr, a_word_offset, b_word_offset):
     """Return dot(float4(e4m3 bytes), float4(e4m3 bytes)) for packed words."""
 
diff --git a/testing/python/cpu/test_blockscaled_e8m0_layout.py b/testing/python/cpu/test_blockscaled_e8m0_layout.py
new file mode 100644
--- /dev/null
+++ b/testing/python/cpu/test_blockscaled_e8m0_layout.py
@@ -0,0 +1,137 @@
+from __future__ import annotations
+
+import pytest
+
+import tilelang.language as T
+
+
+def test_blockscaled_layout_canonical_metadata() -> None:
+    layout = T.BlockScaledLayout.e8m0_k32()
+    assert layout.scale_dtype == "e8m0"
+    assert layout.scale_format == "e8m0_block_k32"
+    assert layout.scale_axis == "contracted_k"
+    assert layout.block_size == 32
+    assert layout.layout == "logical_unswizzled_k_axis_blocks"
+    assert layout.a_scale_shape(64) == (2,)
+    assert layout.b_scale_shape(16, 64) == (16, 2)
+    assert layout.broadcast_b_scale_shape(64) == (2,)
+
+
+@pytest.mark.parametrize(
+    ("kwargs", "message"),
+    [
+        ({"scale_dtype": "fp32"}, "scale_dtype='e8m0'"),
+        ({"axis": "row"}, "axis='contracted_k'"),
+        ({"block_size": 16}, "block_size=32"),
+        ({"layout": "swizzled"}, "logical_unswizzled_k_axis_blocks"),
+    ],
+)
+def test_blockscaled_layout_rejects_non_e8m0_k32(kwargs, message) -> None:
+    with pytest.raises(ValueError, match=message):
+        T.BlockScaledLayout(**kwargs)
+
+
+def test_blockscaled_layout_rejects_non_k32_extent() -> None:
+    layout = T.BlockScaledLayout.e8m0_k32()
+    with pytest.raises(ValueError, match="K divisible by 32"):
+        layout.scale_blocks(48)
+
+
+def test_blockscaled_layout_validates_qk_scale_shapes() -> None:
+    layout = T.BlockScaledLayout.e8m0_k32()
+    layout.validate_scale_shapes(
+        k_extent=64,
+        a_scale_shape=(2,),
+        b_scale_shape=(16, 2),
+        n_extent=16,
+    )
+    layout.validate_scale_shapes(
+        k_extent=64,
+        a_scale_shape=(2,),
+        b_scale_shape=(2,),
+        n_extent=16,
+    )
+    with pytest.raises(ValueError, match=r"A_scale.*K / 32"):
+        layout.validate_scale_shapes(
+            k_extent=64,
+            a_scale_shape=(1,),
+            b_scale_shape=(16, 2),
+            n_extent=16,
+        )
+    with pytest.raises(ValueError, match=r"B_scale.*N, K / 32"):
+        layout.validate_scale_shapes(
+            k_extent=64,
+            a_scale_shape=(2,),
+            b_scale_shape=(16, 1),
+            n_extent=16,
+        )
+
+
+def test_fp8_scaled_matmul_accepts_e8m0_layout_lowering_contract() -> None:
+    layout = T.BlockScaledLayout.e8m0_k32()
+
+    @T.prim_func
+    def blockscaled_qk(
+        A_fp8: T.Tensor((1, 64), "float8_e4m3"),
+        A_scale: T.Tensor((2,), "uint8"),
+        B_fp8: T.Tensor((16, 64), "float8_e4m3"),
+        B_scale: T.Tensor((16, 2), "uint8"),
+        C: T.Tensor((1, 16), "float32"),
+    ):
+        with T.Kernel(1, threads=128):
+            T.fp8_scaled_matmul(
+                A_fp8,
+                A_scale,
+                B_fp8,
+                B_scale,
+                C,
+                transpose_B=True,
+                block_scale_layout=layout,
+            )
+
+    src = str(blockscaled_qk)
+    assert "blockscaled_qk" in src
+    assert layout.scale_format == "e8m0_block_k32"
+    assert layout.scale_index(63) == 1
+
+
+def test_fp8_scaled_matmul_accepts_legacy_metadata_spelling() -> None:
+    @T.prim_func
+    def blockscaled_qk_legacy_attrs(
+        A_fp8: T.Tensor((1, 64), "float8_e4m3"),
+        A_scale: T.Tensor((2,), "uint8"),
+        B_fp8: T.Tensor((16, 64), "float8_e4m3"),
+        B_scale: T.Tensor((2,), "uint8"),
+        C: T.Tensor((1, 16), "float32"),
+    ):
+        with T.Kernel(1, threads=128):
+            T.fp8_scaled_matmul(
+                A_fp8,
+                A_scale,
+                B_fp8,
+                B_scale,
+                C,
+                transpose_B=True,
+                scale_format="e8m0_block_k32",
+                scale_block_size=32,
+            )
+
+    assert "blockscaled_qk_legacy_attrs" in str(blockscaled_qk_legacy_attrs)
+
+
+def test_e8m0_decode_semantics_document_sentinels() -> None:
+    src = T.e8m0_to_float
+    text = getattr(src, "__doc__", "") or ""
+    assert "byte == 0" in text
+    assert "byte == 0xFF" in text
+    assert "byte - 127" in text
