+"""Tests for the ``TVM_METAL_STORAGE_MODE`` runtime override.
+
+The Metal device API caches the storage mode on first ``AllocDataSpace``
+call. We therefore launch a fresh subprocess per scenario so each test
+sees a clean cache and a clean env.
+"""
+
+import json
+import os
+import subprocess
+import sys
+
+import pytest
+
+
+pytestmark = pytest.mark.skipif(
+    sys.platform != "darwin", reason="Metal storage modes only apply on macOS",
+)
+
+
+def _probe_alloc_storage_mode(env_value: str | None) -> str:
+    """Spawn a subprocess that allocates a TVM Metal NDArray and prints its
+    underlying ``MTLBuffer.storageMode`` as a string.
+    """
+
+    script = r"""
+import json
+import sys
+import tvm
+
+if not tvm.metal().exist:
+    print(json.dumps({"skipped": "metal device not available"}))
+    sys.exit(0)
+
+# Trigger one allocation so the cache picks up the env value.
+arr = tvm.nd.empty((4,), dtype="float32", device=tvm.metal())
+
+# Inspect via the underlying MTLBuffer through ctypes / objc_runtime.
+# Storage mode constants are MTLStorageMode in the Metal headers:
+#   Shared = 0, Managed = 1, Private = 2, Memoryless = 3.
+mode = arr._tvm_metal_storage_mode_for_test()  # set by the patch test hook
+mapping = {0: "shared", 1: "managed", 2: "private", 3: "memoryless"}
+print(json.dumps({"mode": mapping.get(mode, f"unknown:{mode}")}))
+"""
+
+    env = os.environ.copy()
+    if env_value is None:
+        env.pop("TVM_METAL_STORAGE_MODE", None)
+    else:
+        env["TVM_METAL_STORAGE_MODE"] = env_value
+
+    result = subprocess.run(
+        [sys.executable, "-c", script],
+        env=env,
+        capture_output=True,
+        text=True,
+        timeout=60,
+    )
+    if result.returncode != 0:
+        pytest.fail(
+            f"Probe failed (env={env_value!r}): rc={result.returncode}\n"
+            f"stdout: {result.stdout}\nstderr: {result.stderr}"
+        )
+    payload = json.loads(result.stdout.strip().splitlines()[-1])
+    if "skipped" in payload:
+        pytest.skip(payload["skipped"])
+    return payload["mode"]
+
+
+def test_default_is_private() -> None:
+    """No env -> Private storage (the historical TVM default)."""
+
+    assert _probe_alloc_storage_mode(None) == "private"
+
+
+def test_shared_env_promotes_to_shared() -> None:
+    """``TVM_METAL_STORAGE_MODE=shared`` allocates CPU-visible buffers."""
+
+    assert _probe_alloc_storage_mode("shared") == "shared"
+
+
+def test_managed_env_promotes_to_managed() -> None:
+    """``TVM_METAL_STORAGE_MODE=managed`` allocates Managed buffers (macOS)."""
+
+    assert _probe_alloc_storage_mode("managed") == "managed"
+
+
+def test_invalid_env_falls_back_to_private() -> None:
+    """Unknown values log a warning and fall back to Private."""
+
+    assert _probe_alloc_storage_mode("not-a-mode") == "private"
