+            f"({tl_tflops:5.3f} TFLOPS)\n"
+            f"  audiohack : {au_mean*1e3:7.3f} +/- {au_std*1e3:5.3f} ms  "
+            f"({au_tflops:5.3f} TFLOPS)\n"
