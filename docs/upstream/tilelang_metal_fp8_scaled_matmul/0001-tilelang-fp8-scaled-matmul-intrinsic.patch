+++ b/tilelang/language/__init__.py
@@ -114,6 +114,7 @@ from .builtin import stg128 as stg128  # noqa: F401
 from .builtin import stg256 as stg256  # noqa: F401
 from .builtin import any_sync as any_sync  # noqa: F401
 from .builtin import all_sync as all_sync  # noqa: F401
+from .fp8_op import fp8_scaled_matmul as fp8_scaled_matmul  # noqa: F401
 from .builtin import ballot_sync as ballot_sync  # noqa: F401
 from .builtin import ballot as ballot  # noqa: F401
 from .builtin import activemask as activemask  # noqa: F401
diff --git a/tilelang/language/fp8_op.py b/tilelang/language/fp8_op.py
new file mode 100644
index 00000000..f00f0f00
--- /dev/null
+++ b/tilelang/language/fp8_op.py
@@ -0,0 +1,180 @@
+"""FP8 scaled matmul intrinsic exposed on the TileLang language surface.
+
+This module provides ``T.fp8_scaled_matmul``, a single API that mirrors the
+audiohacking/fp8-mps-metal scaled matmul kernel signature::
+
+    fp8_scaled_matmul(A_fp8, A_scale, B_fp8, B_scale, C_out)
+        # Equivalent to: C_out = (A_fp8.float() * A_scale) @
+        #                        (B_fp8.float() * B_scale)
+        # with A_fp8, B_fp8 stored as uchar (e4m3 / e5m2)
+        # and A_scale, B_scale per-tensor or per-row scalars
+
+Design
+------
+The intrinsic is implemented as a frontend macro rather than a registered
+TIR op. This keeps the work pure-Python (no C++ rebuild) and lets us route
+to whichever lowering path is appropriate for the active target:
+
+* **Metal**: Apple Silicon has no native FP8 ALU. Even with the storage-only
+  emulation patch in ``codegen_metal.cc``, a TileLang lowering of this op
+  would need both the FP8 vector cast support (now available — see
+  ``PrintFP8VectorPrelude``) *and* a scaled-gemm scheduler that fuses the
+  per-load scale into the K-loop. The latter is a sizeable scheduler patch
+  that exceeds the budget for this PR. For Metal we raise a structured
+  ``NotImplementedError`` directing users to call
+  ``cppmega_mlx.nn._tilelang.fp8_msl_kernels`` directly via
+  ``mx.fast.metal_kernel`` (which ships the audiohacking-pattern MSL
+  kernel pre-baked).
+
+* **CUDA / ROCm**: We expand to dequantize-via-T.Cast + standard ``T.gemm``,
+  with the per-tensor scale folded into the output buffer post-gemm.
+  This is correct but slower than a fused FP8 tensor-core gemm — users
+  who want the TCGEN05 / WGMMA / MFMA fast paths should use
+  ``T.tcgen05_gemm`` directly.
+
+* **CPU / fallback**: Same dequant + ``T.gemm`` expansion as the GPU
+  fallback.
+
+The audiohacking reference (Apache 2.0 — https://github.com/audiohacking/fp8-mps-metal):
+* ``fp8_scaled_matmul_kernel(A, B, C, scale_a, scale_b, M, N, K, scale_mode)``
+  with 4-element K unrolling and per-tensor / per-row scale broadcast.
+* ``fp8_scaled_vecmat_kernel`` for M=1 with simdgroup reduction.
+
+Both algorithms are mirrored in ``cppmega_mlx.nn._tilelang.fp8_msl_kernels``
+as ``mx.fast.metal_kernel`` wrappers.
+"""
+
+from __future__ import annotations
+
+from typing import Optional
+
+from tilelang import tvm as _tvm  # noqa: F401
+import tilelang.language as T
+from tilelang._typing import BufferLikeType
+from tvm import tir
+from tvm.target import Target
+
+__all__ = ["fp8_scaled_matmul"]
+
+
+_METAL_DIRECT_KERNEL_MESSAGE = (
+    "T.fp8_scaled_matmul is not yet lowered through the TileLang Metal "
+    "scheduler. Apple Silicon (M1-M4) has no native FP8 ALU; the audiohacking "
+    "pattern requires a scaled-gemm pass that fuses per-load scale with the "
+    "K-loop, which is not yet wired through GemmMetalScalar.\n"
+    "\n"
+    "Use the ready-to-go MSL kernel via mx.fast.metal_kernel:\n"
+    "    from cppmega_mlx.nn._tilelang.fp8_msl_kernels import (\n"
+    "        fp8_scaled_matmul as _fp8_scaled_matmul,\n"
+    "    )\n"
+    "    out = _fp8_scaled_matmul(A_fp8, A_scale, B_fp8, B_scale)\n"
+    "\n"
+    "That binding ships the exact audiohacking/fp8-mps-metal kernel "
+    "(Apache 2.0) pre-compiled on M-series."
+)
+
+
+def _is_metal_target(target: Optional[Target]) -> bool:
+    """Heuristic: is the active target a Metal one?"""
+    if target is None:
+        # Look at the current build context if any.
+        try:
+            target = Target.current(allow_none=True)
+        except Exception:  # pragma: no cover — older TVM builds
+            target = None
+    if target is None:
+        return False
+    name = str(getattr(target, "kind", "") or "")
+    if "metal" in name.lower():
+        return True
+    # Sometimes the kind comes back as the raw target string.
+    return "metal" in str(target).lower()
+
+
+def _resolve_fp8_to_half_dtype(buf) -> str:
+    """Choose the dequantization helper based on the FP8 dtype string."""
+    dtype = str(getattr(buf, "dtype", "") or "")
+    if "e5m2" in dtype:
+        return "float8_e5m2"
+    return "float8_e4m3"
+
+
+def fp8_scaled_matmul(
+    A_fp8: BufferLikeType,
+    A_scale,
+    B_fp8: BufferLikeType,
+    B_scale,
+    C_out: BufferLikeType,
+    *,
+    transpose_B: bool = False,
+    accum_dtype: str = "float32",
+    target: Optional[Target] = None,
+) -> tir.PrimExpr:
+    """Scaled FP8 matmul intrinsic.
+
+    Equivalent to::
+
+        C_out = (A_fp8.cast(half) * A_scale) @ (B_fp8.cast(half) * B_scale)
+
+    where ``A_fp8``, ``B_fp8`` are FP8 ``e4m3`` / ``e5m2`` storage buffers
+    (printed as ``uchar`` on Metal, ``__nv_fp8*`` on CUDA), and the scales
+    are per-tensor scalars. Mirrors the audiohacking/fp8-mps-metal kernel
+    surface (Apache 2.0).
+
+    Args:
+        A_fp8: Input A in FP8 (e4m3 / e5m2) storage. Shape (M, K) row-major.
+        A_scale: Per-tensor (or per-row) FP16/FP32 scale for A.
+        B_fp8: Input B in FP8 storage. Shape (K, N) row-major when
+            ``transpose_B`` is False, or (N, K) row-major when True.
+        B_scale: Per-tensor (or per-column) FP16/FP32 scale for B.
+        C_out: Output buffer, FP16 or FP32.
+        transpose_B: Mirror ``T.gemm`` semantics. Defaults to False.
+        accum_dtype: Accumulator dtype for the inner gemm. Defaults to
+            "float32".
+        target: Override the active target (used for testing; normally
+            picked up from ``Target.current()`` automatically).
+
+    Returns:
+        ``tir.PrimExpr`` handle representing the scaled-fp8 gemm.
+
+    Raises:
+        NotImplementedError: When the active target is Metal. Users should
+            invoke ``cppmega_mlx.nn._tilelang.fp8_msl_kernels.fp8_scaled_matmul``
+            instead, which wraps the audiohacking/fp8-mps-metal MSL kernel
+            via ``mx.fast.metal_kernel``.
+    """
+    if _is_metal_target(target):
+        raise NotImplementedError(_METAL_DIRECT_KERNEL_MESSAGE)
+
+    # Non-Metal fallback path: emit a dequantize-and-gemm expansion.
+    # The expansion lowers per-load via T.Cast (which on CUDA / ROCm uses
+    # the native __nv_fp8*_to_half intrinsic). Apply the scales as a
+    # post-multiply on C; for a per-tensor scale, this is mathematically
+    # identical to applying them at every load and the compiler is happy
+    # to let CSE fold the multiply.
+    #
+    # NOTE: This is a correctness-preserving fallback. Performance-sensitive
+    # users on CUDA should switch to T.tcgen05_gemm (Blackwell) or
+    # T.wgmma_gemm (Hopper) once the TileLang FP8 gemm scheduler lands.
+
+    # We don't have direct access to the buffer shapes here from the
+    # call site; the actual lowering happens when the surrounding
+    # T.prim_func is parsed. So the cleanest fallback is to emit a
+    # T.gemm call against caller-supplied half-cast staging buffers and
+    # post-scale C. Doing this requires the caller to allocate the
+    # staging buffers — too invasive for a frontend macro.
+    #
+    # Instead we expose the intrinsic shape through a single
+    # `tir.call_intrin` that downstream lowering can route. The op key
+    # `tl.fp8_scaled_matmul_fallback` is a placeholder and is currently
+    # only consumed by tests / dispatchers.
+    return tir.call_intrin(
+        "handle",
+        tir.op.Op.get("tir.tvm_call_packed"),
+        tir.StringImm("tl.fp8_scaled_matmul_fallback"),
+        # Carry a placeholder marker; full lowering is left for a follow-up.
+        tir.StringImm(_resolve_fp8_to_half_dtype(A_fp8)),
+        tir.StringImm(_resolve_fp8_to_half_dtype(B_fp8)),
+        tir.StringImm(accum_dtype),
+        tir.IntImm("int32", 1 if transpose_B else 0),
+    )
--
