+    # even though every individual product is bit-exact. We allow that.
+    assert abs_max < 5e-2, (
+        f"vecmat parity failed: max abs err {abs_max:.3g}\n"
+        f"c_out range: [{c_out.cpu().min():.3f}, {c_out.cpu().max():.3f}]\n"
