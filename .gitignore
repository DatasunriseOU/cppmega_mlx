# Local Python environments and interpreter caches.
.venv
.venv/
__pycache__/
*.py[cod]
*$py.class

# Test and tooling caches.
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyright/

# Build artifacts.
*.egg-info/

# Local Metal GPU traces (multi-hundred-MB Apple Xcode capture bundles).
*.gputrace
docs/upstream/tilelang_metal_mamba3/captures/

# Codex/agent runtime logs are local coordination artifacts.
.codex/agent-logs/
.claude/

# Large real-data samples copied from GB10 for local-only smoke tests.
data/parquet_samples/

# Beads / Dolt files (added by bd init)
.beads/
.dolt/
*.db
.beads-credential-key
