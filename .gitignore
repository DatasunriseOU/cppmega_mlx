# Local Python environments and interpreter caches.
.venv
.venv/
__pycache__/
*.py[cod]
*$py.class

# Test and tooling caches.
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyright/

# Build artifacts.
*.egg-info/
build/
cppmega_mlx/training/native_optim/*.so
cppmega_mlx/training/native_optim/*.dylib
cppmega_mlx/training/native_optim/*.metallib

# Local Metal GPU traces (multi-hundred-MB Apple Xcode capture bundles).
*.gputrace
docs/upstream/tilelang_metal_mamba3/captures/

# Codex/agent runtime logs are local coordination artifacts.
.codex/agent-logs/
.claude/

# Large real-data samples copied from GB10 for local-only smoke tests.
data/parquet_samples/

# Beads / Dolt files (added by bd init)
.beads/
.dolt/
*.db
.beads-credential-key
loop_vectorize.o

.gemini/
gha-creds-*.json
bench/runs/*.json
bench/runs/*
docs/tilelang_ports/mamba3_path_b_vs_c_b1_t2048.diff
docs/tilelang_ports/mamba3_path_c_lowered_b1_t2048.metal
reports/profiling/*.diff
reports/profiling/*.metal
reports/profiling/xctrace_*.*/*
reports/*/*/*.json
.gitignore
reports/profiling/xctrace_*.xml
reports/profiling/xctrace_*.json
reports/profiling/*.json
